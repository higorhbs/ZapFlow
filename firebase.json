{
  "functions": {
    "source": "apps/api",
    "runtime": "nodejs20",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "site": "zapflow-higor-2026",
    "public": "apps/web/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "headers": [
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      }
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/businesses/*/conversations", "destination": "/businesses/app/conversations.html" },
      { "source": "/businesses/*/catalog", "destination": "/businesses/app/catalog.html" },
      { "source": "/businesses/*/appointments", "destination": "/businesses/app/appointments.html" },
      { "source": "/businesses/*/payments", "destination": "/businesses/app/payments.html" },
      { "source": "/businesses/*/faqs", "destination": "/businesses/app/faqs.html" },
      { "source": "/businesses/*/whatsapp", "destination": "/businesses/app/whatsapp.html" },
      { "source": "/businesses/*/settings", "destination": "/businesses/app/settings.html" }
    ]
  }
}
