{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "site": "zapflow-higor-2026",
    "public": "apps/web/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "headers": [
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      }
    ],
    "rewrites": [
      { "source": "/businesses/*/catalog", "destination": "/index.html" },
      { "source": "/businesses/*/conversations", "destination": "/index.html" },
      { "source": "/businesses/*/appointments", "destination": "/index.html" },
      { "source": "/businesses/*/faqs", "destination": "/index.html" },
      { "source": "/businesses/*/whatsapp", "destination": "/index.html" },
      { "source": "/businesses/*/settings", "destination": "/index.html" }
    ]
  }
}
