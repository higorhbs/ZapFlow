{
  "name": "zapflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "postinstall": "node scripts/prepare-hosting.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "google:oauth-setup": "node scripts/google-oauth-setup.mjs",
    "prepare:hosting": "node scripts/prepare-hosting.mjs",
    "build:hosting": "npm run prepare:hosting && FIREBASE_STATIC=1 npm run build --workspace=@zapflow/web",
    "deploy:hosting": "npm run build:hosting && firebase deploy --only hosting",
    "deploy:firestore": "firebase deploy --only firestore"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "firebase": "^11.6.0"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
