{
  "name": "flowdesk",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "postinstall": "node scripts/prepare-hosting.mjs",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @flowdesk/web dev",
    "dev:api": "pnpm --filter @flowdesk/api dev",
    "build": "turbo run build",
    "google:oauth-setup": "node scripts/google-oauth-setup.mjs",
    "prepare:hosting": "node scripts/prepare-hosting.mjs",
    "build:hosting": "pnpm run prepare:hosting && pnpm --filter @flowdesk/web icons:generate && FIREBASE_STATIC=1 pnpm --filter @flowdesk/web build",
    "deploy:hosting": "pnpm run build:hosting && firebase deploy --only hosting",
    "preview:hosting": "pnpm run build:hosting && firebase emulators:exec --only hosting \"echo Abra http://127.0.0.1:5000 (ou porta exibida acima)\"",
    "deploy:firestore": "firebase deploy --only firestore",
    "oracle:prep-env": "bash scripts/oracle/prep-local-env.sh",
    "stripe:sync-prices": "node scripts/stripe-sync-prices.mjs",
    "setup:billing-env": "node scripts/setup-billing-env.mjs",
    "setup:github-deploy": "node scripts/setup-github-deploy-secrets.mjs",
    "setup:server-env": "node scripts/setup-server-env.mjs",
    "setup:vm-env": "node scripts/generate-vm-env.mjs",
    "oracle:setup-billing": "bash scripts/oracle/setup-billing-vm.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react": "$react",
      "react-dom": "$react-dom",
      "firebase": "^11.6.0"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
