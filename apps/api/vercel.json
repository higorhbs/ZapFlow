{
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npx turbo run build --filter=@zapflow/api...",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": [
        "../../packages/firebase/dist/**",
        "../../packages/shared/dist/**",
        "../../packages/whatsapp-client/dist/**"
      ]
    }
  },
  "env": {
    "ENABLE_WORKERS": "false",
    "NODE_ENV": "production"
  }
}
