    "date-fns": "^3.6.0",
    "fastify": "^4.28.1",
    "fastify-raw-body": "^4.3.0",
    "firebase-functions": "^6.0.1",
    "ioredis": "^5.4.1",
    "stripe": "^22.2.0",
