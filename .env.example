# API Firebase Functions (billing/webhooks/privacy) — raiz do monorepo
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
PRIVACY_RETENTION_INTERVAL_HOURS=24
LOG_LEVEL=info

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
